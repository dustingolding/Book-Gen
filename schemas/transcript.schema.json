{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sidelinewire.local/schemas/transcript.schema.json",
  "title": "Transcript",
  "type": "object",
  "required": [
    "run_date",
    "title",
    "language",
    "segments",
    "citation_coverage",
    "numeric_fidelity",
    "verified"
  ],
  "properties": {
    "run_date": {"type": "string", "format": "date"},
    "title": {"type": "string"},
    "language": {"type": "string"},
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["segment", "text", "citations"],
        "properties": {
          "segment": {"type": "string"},
          "text": {"type": "string", "minLength": 1},
          "citations": {
            "type": "array",
            "items": {"type": "string", "format": "uri"}
          }
        }
      }
    },
    "citation_coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "numeric_fidelity": {"type": "number", "minimum": 0, "maximum": 1},
    "verified": {"type": "boolean"}
  }
}
