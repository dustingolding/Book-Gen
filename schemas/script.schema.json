{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sidelinewire.local/schemas/script.schema.json",
  "title": "SLW Script v1",
  "type": "object",
  "required": ["meta", "sections"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["process_date", "show_name", "hosts", "target_runtime_minutes", "wpm_baseline"],
      "properties": {
        "process_date": {"type": "string", "format": "date"},
        "show_name": {"type": "string"},
        "hosts": {
          "type": "array",
          "minItems": 2,
          "items": {"type": "string"}
        },
        "target_runtime_minutes": {"type": "number"},
        "wpm_baseline": {"type": "integer"}
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "turns"],
        "properties": {
          "name": {"type": "string"},
          "turns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["speaker", "text", "source_ids"],
              "properties": {
                "speaker": {"type": "string"},
                "text": {"type": "string", "minLength": 1},
                "source_ids": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              }
            }
          }
        }
      }
    }
  }
}
