{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sidelinewire.local/schemas/qa_report.schema.json",
  "title": "SLW QA Report",
  "type": "object",
  "required": ["status", "metrics", "issues"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  }
}
